generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  tenantId       String
  name           String
  email          String   @unique
  passwordHash   String
  company        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leads          Lead[]
  automations    Automation[]
  pixCheckouts   PixCheckout[]
  executions     Execution[]
  scheduledJobs  ScheduledJob[]
}

model Lead {
  id            String   @id @default(cuid())
  tenantId      String
  userId        String
  name          String
  channel       String
  stage         String
  email         String
  phone         String
  lastMessage   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Automation {
  id            String   @id @default(cuid())
  tenantId      String
  userId        String
  name          String
  channel       String
  trigger       String
  status        String
  message       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  executions    Execution[]
  scheduledJobs ScheduledJob[]
}

model PixCheckout {
  id             String   @id @default(cuid())
  tenantId        String
  userId         String
  customerName   String
  customerEmail  String
  amount         Decimal  @db.Decimal(10, 2)
  description    String
  provider       String
  externalId     String?
  status         String
  qrCodeText     String?
  copyPasteCode  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Tenant {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  users         User[]
  leads         Lead[]
  automations   Automation[]
  pixCheckouts  PixCheckout[]
  executions    Execution[]
  scheduledJobs ScheduledJob[]
  integrations  IntegrationConfig[]
}

model Execution {
  id             String     @id @default(cuid())
  tenantId       String
  userId         String
  automationId   String
  automationName String
  channel        String
  contactName    String
  recipient      String
  status         String
  preview        String
  createdAt      DateTime   @default(now())
  tenant         Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  automation     Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
}

model ScheduledJob {
  id             String     @id @default(cuid())
  tenantId       String
  userId         String
  automationId   String
  automationName String
  channel        String
  contactName    String
  recipient      String
  message        String
  scheduledFor   DateTime
  status         String
  createdAt      DateTime   @default(now())
  tenant         Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  automation     Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
}

model IntegrationConfig {
  id          String   @id @default(cuid())
  tenantId    String
  channel     String
  connected   Boolean  @default(false)
  label       String
  configJson  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, channel])
}
